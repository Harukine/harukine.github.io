---
import Card from './ui/Card.astro';
---

<Card>
  <h2>Professional Summary</h2>
  <p class="summary">
    <strong>Senior Software Engineer</strong> with 8 years of experience specializing in
    <strong>Platform Engineering</strong>, production-grade <strong>AI (RAG)</strong>, and
    cloud-native architectures. Currently looking to relocate to <strong>Tokyo, Japan</strong>, I
    bring expertise in building high-availability <strong>modern .NET 8 and TypeScript</strong> platforms on
    <strong>Azure and Kubernetes</strong> with a focus on security, cost-optimization, and
    automated CI/CD pipelines.
  </p>
</Card>

<style>
  .summary {
    font-size: 14.5px;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .summary strong {
    color: var(--text-primary);
    font-weight: 600;
  }
</style>
